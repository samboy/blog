 	else if ((unsigned char)c < ' ' || c == 0x7f)
 		co++; // display as ^X, use 2 columns
+	else if ((unsigned char)c >= 128 && (unsigned char)c < 192)
+		return co; // Do not advance in middle of multichar UTF-8 sequence
 	return co + 1;
 }
 
@@ -1069,6 +1071,7 @@
