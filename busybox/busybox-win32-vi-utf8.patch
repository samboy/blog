@@ -1088,7 +1091,13 @@
 	tp = screenbegin;	// index into text[] of top line
 
 	// compare text[] to screen[] and mark screen[] lines that need updating
-	for (li = 0; li < rows - 1; li++) {
+	low = 0; high = rows - 1;
+    if(full_screen == 2) { // Only update 1 line
+        low = crow; 
+        high = crow + 1; 
+        tp = begin_line(dot);
+    }
+	for (li = low; li < high; li++) {
 		int cs, ce;				// column start & end
 		char *out_buf;
 		// format current text line
@@ -1888,6 +1897,9 @@
 	undo_queue_commit();
 	if (dot > text && dot[-1] != '\n')
